model Program {
  id            String          @id @default(uuid())
  name          String
  description   String?
  durationWeeks Int
  category      ProgramCategory @default(STRENGTH_TRAINING)

  coachId String
  coach   User   @relation("CoachPrograms", fields: [coachId], references: [id], onDelete: Cascade)

  athletes User[]       @relation("AthletePrograms")
  days     ProgramDay[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([coachId])
}
